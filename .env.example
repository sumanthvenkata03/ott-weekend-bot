@"
# ───── LLM ─────
# Using Claude Code CLI authenticated via Max plan — no API key needed

# ───── OTT Releases (Week 1–2) ─────
TMDB_API_KEY=
OMDB_API_KEY=

# ───── News Engine (Week 3) ─────
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ott-weekend-bot:v0.1 (by /u/yourhandle)
NITTER_INSTANCES=https://nitter.net,https://nitter.privacydev.net,https://nitter.poast.org

# ───── Delivery ─────
NOTION_TOKEN=
NOTION_RELEASES_DB_ID=
NOTION_NEWS_DB_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ───── Storage ─────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=ott-weekend-bot-assets

# ───── Visual gen (Week 4–5) ─────
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=
PEXELS_API_KEY=

# ───── Runtime config ─────
IMPORTANCE_THRESHOLD=55
MAX_NEWS_POSTS_PER_DAY=6
SOUTH_INDUSTRY_BOOST=1.3
"@ | Out-File -Encoding utf8 .env.example

Copy-Item .env.example .env